# CardGPT Environment Variables
# Copy this file to .env.local for local development

# AI Extraction API Keys (at least one required for T&C extraction)
# OpenAI is tried first, then Anthropic. If neither is set, mock extraction is used.

# OpenAI API Key (uses gpt-4o-mini)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API Key (uses claude-3-5-haiku) - fallback if OpenAI not set
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Upstash Redis (card data storage in production)
# Auto-added by Vercel Marketplace integration (Upstash Redis)
# Variable names follow the Vercel integration naming convention
REAL_STORAGE_KV_REST_API_URL=
REAL_STORAGE_KV_REST_API_TOKEN=
